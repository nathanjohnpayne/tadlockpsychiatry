#!/usr/bin/env bash
# check_no_bare_gh_writes
#
# Standing guard for #411: interactive agent-driven GitHub writes must
# use token-verifying wrappers or a documented exemption.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
TMP_OUT="$(mktemp "${TMPDIR:-/tmp}/mergepath-no-bare-gh-writes.XXXXXX")"
trap 'rm -f "$TMP_OUT"' EXIT

FILES=()
while IFS= read -r -d '' file; do
  rel="${file#"$REPO_ROOT"/}"
  case "$rel" in
    *.md) continue ;;                                # documentation examples, not executable script flow
    scripts/daily-feedback-rollup.sh) continue ;;    # workflow/reporting surface, #412
    scripts/sweep-unresolved-feedback/*) continue ;; # workflow/reporting surface, #412
    scripts/post-phase-4b-handoff.sh) continue ;;    # GraphQL read helper, #412
    scripts/ci/*) continue ;;                        # tests/checks intentionally stub gh
  esac
  FILES+=("$file")
done < <(find "$REPO_ROOT/scripts" -type f -print0 | LC_ALL=C sort -z)

if [ "${#FILES[@]}" -eq 0 ]; then
  echo "check_no_bare_gh_writes: PASS (no files to scan)"
  exit 0
fi

set +e
awk -v root="$REPO_ROOT/" '
function bare_write(line) {
  if (line ~ /^[[:space:]]*($|#)/) return 0
  if (line ~ /NO_BARE_GH_WRITE_EXEMPT:/) return 0
  if (line ~ /\\`[^`]*gh[[:space:]]+(pr|issue|api)[^`]*\\`/) return 0
  if (line ~ /^[[:space:]]*(echo|printf)[[:space:]]/ &&
      line !~ /\$\([[:space:]]*gh[[:space:]]+(pr|issue|api)[[:space:]]/ &&
      line !~ /`[^`]*gh[[:space:]]+(pr|issue|api)[^`]*`/) return 0
  if (line ~ /gh-as-(author|reviewer)\.sh[^;&|]*--[[:space:]]+gh/) return 0
  if (line ~ /\$"?[A-Z_]*AS_(AUTHOR|REVIEWER)"?[[:space:]]+--[[:space:]]+gh/) return 0
  if (line ~ /(^|[[:space:]])(sync_author_gh|bootstrap::run_author_gh|bootstrap::author_gh|ghp_gh|gh_reviewer|gh_pat)[[:space:]]+/) return 0
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+pr[[:space:]]+(-R[[:space:]]+[^[:space:]]+[[:space:]]+|--repo[[:space:]]+[^[:space:]]+[[:space:]]+|--repo=[^[:space:]]+[[:space:]]+)?(create|merge|review|comment|edit)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+pr[[:space:]]+close([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+issue[[:space:]]+(create|comment|edit|close)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+repo[[:space:]]+(create|delete|edit)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+label[[:space:]]+(create|edit|delete)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+secret[[:space:]]+set([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+variable[[:space:]]+set([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+project[[:space:]]+(create|edit|field-create|item-add|item-edit)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+api[[:space:]].*(-X[[:space:]]+|--method[[:space:]]+)(POST|PATCH|PUT|DELETE)([[:space:]]|$)/) return 1
  if (line ~ /(^|[^A-Za-z0-9_.\/-])gh[[:space:]]+api[[:space:]]+graphql/ && line ~ /(mutation|resolveReviewThread|addPullRequestReviewThreadReply|addComment|updateIssue|closeIssue)/) return 1
  return 0
}
{
  rel = FILENAME
  sub("^" root, "", rel)
  if (bare_write($0)) {
    print rel ":" FNR ":" $0
    found = 1
  }
}
END { exit found ? 1 : 0 }
' "${FILES[@]}" >"$TMP_OUT" 2>/dev/null
rc=$?
set -e

if [ "$rc" -ne 0 ]; then
  echo "check_no_bare_gh_writes: FAIL" >&2
  echo "Bare guarded gh writes must use scripts/gh-as-author.sh / scripts/gh-as-reviewer.sh or carry NO_BARE_GH_WRITE_EXEMPT with a reason." >&2
  sed 's/^/  - /' "$TMP_OUT" >&2
  exit 1
fi

echo "check_no_bare_gh_writes: PASS"
exit 0
