#!/usr/bin/env bash
# scripts/ci/check_verify_propagation_pr — CI entry point for the
# propagation-PR review lane's faithful-mirror verifier (#264 / #268).
#
# Wraps tests/test_verify_propagation_pr.sh so the repo_lint workflow's
# "run all scripts/ci/check_*" loop picks it up. The verifier
# (scripts/workflow/verify-propagation-pr.sh) is security-load-bearing
# — it is what makes it safe for the lane to skip Phase 4 external
# review — so its test suite is a hard CI gate.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# The verifier and its segment-local protected-path matcher
# (scripts/workflow/match_protected_paths.sh, #471) are both
# security-load-bearing for the propagation lane, so both test suites are
# hard CI gates here.
TESTS=(
  "tests/test_verify_propagation_pr.sh"
  "tests/test_match_protected_paths.sh"
)

for rel in "${TESTS[@]}"; do
  full="$REPO_ROOT/$rel"
  if [ ! -f "$full" ]; then
    # Hard error in BOTH canonical and consumer checkouts — deliberately
    # NO consumer-safe skip here, unlike check_workflow_verify_propagation_templated
    # (whose test is NOT propagated, so it is legitimately absent in a
    # consumer). Both wrapped tests are `consumers: all` AND listed in the
    # scripts/ci/ kit `requires:` in .mergepath-sync.yml, so they travel to
    # EVERY consumer. A missing test in a consumer therefore means
    # propagation BROKE (the kit failed to deliver a required file), not
    # that the test is legitimately absent — surface it rather than
    # silently skipping a security-load-bearing check. A manifest-gated
    # skip here masks exactly that propagation failure (Codex P2 on PR
    # #477 reproduced the fail-open; #467 r2).
    echo "check_verify_propagation_pr: ERROR (missing $rel)" >&2
    exit 1
  fi
  echo "check_verify_propagation_pr: running $rel"
  bash "$full"
done
