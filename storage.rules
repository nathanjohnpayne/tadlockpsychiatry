rules_version = '2';

// Firebase Cloud Storage rules for tadlockpsychiatry.com.
//
// Closes the gap Codex flagged on PR #2 (issue #3): the design-prototype
// source files (content.jsx, direction-{1,2,3}.jsx) and the practice
// portrait used to be served from public Hosting; any unauthenticated
// `curl` could pull them. Now they live in this bucket under
// `protected/` and are only readable by an allowlisted Firebase Auth
// session. The Hosting gate / menu / direction routes themselves are
// still gated client-side by the in-page allowlist guard in
// `src/auth.js`; this is the *server-side* enforcement that follows.
//
// Why Storage Rules instead of a Cloud Function (which issue #3
// originally proposed): the GCP organization's Domain Restricted
// Sharing org policy (`constraints/iam.allowedPolicyMemberDomains`)
// blocks `allUsers` invoker on Cloud Run / Cloud Functions, so a
// function would be blocked at Cloud Run's IAM gate before the
// function code's own auth check could run. Storage Rules sidestep
// that — they're enforced at the bucket layer by the Firebase
// Storage SDK's auth-aware request signing, no public-invoker grant
// needed. See the PR body for the full pivot rationale.
service firebase.storage {
  match /b/{bucket}/o {

    // Protected design-preview content. Mirrors the allowlist in
    // src/auth.js (kept in sync by hand for v1; the obvious follow-up
    // is to move the list into Firestore + a small admin tool so the
    // two locations can share a single source of truth). Lower-cased
    // compare matches the client-side check.
    match /protected/{file=**} {
      allow read: if request.auth != null
                   && request.auth.token.email != null
                   && request.auth.token.email.lower() in [
                        'nathan@nathanpayne.com',
                        'sterling.tadlock@gmail.com'
                      ];
      allow write: if false;
    }

    // Default-deny everything else in the bucket. We don't host
    // anything else here for v1, but this guards future accidents.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
