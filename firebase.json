{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/.*/**",
      ".git/**",
      ".github/**",
      ".claude/**",
      ".cursor/**",
      ".vscode/**",
      "**/node_modules/**",
      "**/*.md",
      "AGENTS.md",
      "CLAUDE.md",
      "REVIEW_POLICY.md",
      "DEPLOYMENT.md",
      "CONTRIBUTING.md",
      "SECURITY.md",
      "ai_agent_tooling_standard.md",
      ".repo-template.yml",
      ".coderabbit.yml",
      ".gitignore",
      ".ai_context.md",
      "scripts/**",
      "tests/**",
      "rules/**",
      "specs/**",
      "plans/**",
      "docs/**",
      "bugs/**",
      "functions/**",
      "packaging/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          }
        ]
      }
    ]
  }
}
